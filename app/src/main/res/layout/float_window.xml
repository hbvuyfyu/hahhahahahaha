<?xml version="1.0" encoding="utf-8"?>
<!-- Root container: stacks the FAB bubble + expanded panel -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- EXPANDED PANEL -->
    <LinearLayout
        android:id="@+id/float_expanded_panel"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_float_panel"
        android:padding="12dp"
        android:elevation="16dp"
        android:visibility="gone"
        android:layout_marginBottom="64dp">

        <!-- Header row (drag handle + status) -->
        <LinearLayout
            android:id="@+id/float_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_float_target"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/color_text_primary"
                android:textSize="11sp"
                android:maxLines="1"
                android:text="VCam Active"/>

            <TextView
                android:id="@+id/tv_float_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_silver_dark"
                android:textSize="10sp"
                android:maxLines="1"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="10dp"/>

        <!-- Slot buttons row 1-4 (images) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMG"
                android:textColor="@color/color_silver_dark"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_float_slot_1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_card_elevated"
                android:textColor="@color/color_text_secondary"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="2"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_card_elevated"
                android:textColor="@color/color_text_secondary"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="3"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_card_elevated"
                android:textColor="@color/color_text_secondary"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_4"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_card_elevated"
                android:textColor="@color/color_text_secondary"/>

        </LinearLayout>

        <!-- Slot buttons row 5-8 (videos) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VID"
                android:textColor="@color/color_video_accent"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_float_slot_5"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_video_accent_bg"
                android:textColor="@color/color_video_accent"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_6"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_video_accent_bg"
                android:textColor="@color/color_video_accent"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_7"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_video_accent_bg"
                android:textColor="@color/color_video_accent"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_float_slot_8"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="@color/color_video_accent_bg"
                android:textColor="@color/color_video_accent"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="10dp"/>

        <!-- Mirror + Stop row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="6dp">

            <ImageButton
                android:id="@+id/btn_float_mirror"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_mirror"
                android:background="@drawable/bg_action_btn_accent"
                android:tint="@color/white"
                android:padding="9dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Mirror"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_float_mirror"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mirror_off"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="10sp"
                    android:gravity="start"/>

                <TextView
                    android:id="@+id/tv_float_slot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="حقل 1"
                    android:textColor="@color/color_accent"
                    android:textSize="10sp"
                    android:gravity="start"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_float_stop"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_power_off"
                android:background="@drawable/bg_action_btn_stop"
                android:tint="@color/white"
                android:padding="9dp"
                android:contentDescription="Stop"/>

        </LinearLayout>

    </LinearLayout>

    <!-- FAB bubble (always visible) -->
    <ImageButton
        android:id="@+id/btn_float_toggle"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@drawable/ic_vcam_notif"
        android:background="@drawable/bg_fab_main"
        android:tint="@color/color_accent"
        android:padding="14dp"
        android:elevation="8dp"
        android:layout_gravity="bottom|end"
        android:contentDescription="Toggle panel"/>

</FrameLayout>
