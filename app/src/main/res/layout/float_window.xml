<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ══ EXPANDED PANEL ══ -->
    <LinearLayout
        android:id="@+id/float_expanded_panel"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_float_panel"
        android:padding="12dp"
        android:elevation="16dp"
        android:visibility="gone"
        android:layout_marginBottom="62dp">

        <!-- Header: drag handle + status -->
        <LinearLayout
            android:id="@+id/float_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_float_target"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/color_text_primary"
                android:textSize="11sp"
                android:maxLines="1"
                android:text="VCam Active"/>

            <TextView
                android:id="@+id/tv_float_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_silver_dark"
                android:textSize="10sp"
                android:maxLines="1"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- Mode tabs: IMG / VID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btn_tab_images"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📷 IMG"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_active"
                android:textColor="@color/white"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_tab_videos"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="🎬 VID"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_inactive"
                android:textColor="#AAAAAA"/>

        </LinearLayout>

        <!-- Slot buttons 1-4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_slot_1"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_active"
                android:textColor="@color/white"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_slot_2"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="2"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_inactive"
                android:textColor="#AAAAAA"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_slot_3"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="3"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_inactive"
                android:textColor="#AAAAAA"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_slot_4"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_slot_btn_inactive"
                android:textColor="#AAAAAA"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="8dp"/>

        <!-- Quick controls row: Preview + Rotate + Mirror + Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btn_float_preview"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_eye"
                android:background="@drawable/bg_action_btn_accent"
                android:tint="@color/white"
                android:padding="8dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Preview"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <ImageButton
                    android:id="@+id/btn_float_rotate"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_rotate_cw"
                    android:background="@drawable/bg_action_btn_accent"
                    android:tint="@color/white"
                    android:padding="8dp"
                    android:contentDescription="Rotate"/>

                <TextView
                    android:id="@+id/tv_rotate_label"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="0°"
                    android:textColor="@color/color_silver_dark"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <ImageButton
                    android:id="@+id/btn_float_mirror"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_mirror"
                    android:background="@drawable/bg_action_btn_accent"
                    android:tint="@color/white"
                    android:padding="8dp"
                    android:contentDescription="Mirror"/>

                <TextView
                    android:id="@+id/tv_mirror_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عكس"
                    android:textColor="@color/color_silver_dark"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_float_stop"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_power_off"
                android:background="@drawable/bg_action_btn_stop"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="Stop"/>

        </LinearLayout>

        <!-- Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_float_slot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="حقل 1"
                android:textColor="@color/color_accent"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tv_float_mirror"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mirror_off"
                android:textColor="@color/color_text_secondary"
                android:textSize="10sp"/>

        </LinearLayout>

        <!-- Expand / More controls toggle -->
        <Button
            android:id="@+id/btn_float_expand"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:text="▼ المزيد من الأزرار"
            android:textSize="10sp"
            android:textColor="@color/color_silver_dark"
            android:backgroundTint="@color/color_card_elevated"
            android:layout_marginBottom="4dp"/>

        <!-- ══ EXTRA CONTROLS (collapsible) ══ -->
        <LinearLayout
            android:id="@+id/float_extra_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"/>

            <!-- Zoom controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZOOM"
                    android:textColor="@color/color_silver_dark"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btn_float_zoom_out"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:text="−"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tv_float_zoom_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1.0×"
                    android:textColor="@color/color_accent"
                    android:textSize="11sp"
                    android:gravity="center"/>

                <Button
                    android:id="@+id/btn_float_zoom_in"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:text="+"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"/>

            </LinearLayout>

            <!-- Scale controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCALE"
                    android:textColor="@color/color_silver_dark"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btn_float_scale_down"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:text="−"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tv_float_scale_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="100%"
                    android:textColor="@color/color_accent"
                    android:textSize="11sp"
                    android:gravity="center"/>

                <Button
                    android:id="@+id/btn_float_scale_up"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:text="+"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"/>

            </LinearLayout>

            <!-- Pan controls cross -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Up -->
                <Button
                    android:id="@+id/btn_float_pan_up"
                    android:layout_width="36dp"
                    android:layout_height="28dp"
                    android:text="▲"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"
                    android:layout_marginBottom="2dp"/>

                <!-- Left + Reset + Right -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="2dp">

                    <Button
                        android:id="@+id/btn_float_pan_left"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:text="◀"
                        android:textSize="11sp"
                        android:padding="0dp"
                        android:backgroundTint="@color/color_card_elevated"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginEnd="2dp"/>

                    <Button
                        android:id="@+id/btn_float_pan_reset"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:text="○"
                        android:textSize="12sp"
                        android:padding="0dp"
                        android:backgroundTint="@color/color_steel"
                        android:textColor="@color/white"
                        android:layout_marginEnd="2dp"/>

                    <Button
                        android:id="@+id/btn_float_pan_right"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:text="▶"
                        android:textSize="11sp"
                        android:padding="0dp"
                        android:backgroundTint="@color/color_card_elevated"
                        android:textColor="@color/color_text_primary"/>

                </LinearLayout>

                <!-- Down -->
                <Button
                    android:id="@+id/btn_float_pan_down"
                    android:layout_width="36dp"
                    android:layout_height="28dp"
                    android:text="▼"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:backgroundTint="@color/color_card_elevated"
                    android:textColor="@color/color_text_primary"/>

            </LinearLayout>

        </LinearLayout>
        <!-- end float_extra_controls -->

    </LinearLayout>
    <!-- end float_expanded_panel -->

    <!-- ══ FAB BUBBLE ══ -->
    <ImageView
        android:id="@+id/float_fab_main"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@drawable/ic_vcam_notif"
        android:background="@drawable/bg_fab_main"
        android:tint="@color/color_accent"
        android:padding="14dp"
        android:elevation="8dp"
        android:layout_gravity="bottom|end"
        android:contentDescription="Toggle panel"/>

</FrameLayout>
