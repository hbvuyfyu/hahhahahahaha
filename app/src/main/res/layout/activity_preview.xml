<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_preview_dialog">

    <TextView
        android:id="@+id/tv_preview_slot_label"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="معاينة"
        android:textColor="@color/color_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_preview_close"/>

    <ImageButton
        android:id="@+id/btn_preview_close"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_action_btn_danger"
        android:tint="@color/white"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="Close"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        android:id="@+id/divider_top"
        app:layout_constraintTop_toBottomOf="@id/tv_preview_slot_label"/>

    <ImageView
        android:id="@+id/iv_preview_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="matrix"
        android:background="@color/color_primary_dark"
        android:contentDescription="Preview"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_surface"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_preview_zoom_out"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="−"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:padding="0dp"
            android:backgroundTint="@color/color_card_elevated"
            app:cornerRadius="22dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tv_preview_zoom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="100%"
            android:textColor="@color/color_accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_preview_zoom_in"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="+"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:padding="0dp"
            android:backgroundTint="@color/color_accent"
            app:cornerRadius="22dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>