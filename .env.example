# ═══════════════════════════════════════════════════════════════════════════
# Virtual Cam — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# On Railway, add these as environment variables in your project settings.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server Configuration ──────────────────────────────────────────────────
# The port the server listens on (Railway sets PORT automatically)
PORT=3000

# The public URL of your deployed server (used for OxaPay callback and return URLs)
# On Railway, this is your Railway app URL, e.g. https://your-app-name.up.railway.app
SERVER_URL=https://your-app-name.up.railway.app

# ── Supabase Configuration ────────────────────────────────────────────────
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OxaPay Configuration ─────────────────────────────────────────────────
# Get your Merchant API Key from OxaPay dashboard:
# https://app.oxapay.com/merchant
OXAPAY_MERCHANT_KEY=your-oxapay-merchant-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# ANDROID APP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# In the Android app, the server URL is stored in SharedPreferences.
# You need to set it ONCE on the device by calling:
#
#   ApiClient.setServerUrl(context, "https://your-app-name.up.railway.app")
#
# OR you can hardcode it in the app by modifying:
#   app/src/main/java/com/vcam/utils/ApiClient.kt
#
# In the getServerUrl() method, change the default value:
#   prefs(context).getString(KEY_SERVER_URL, "https://your-app-name.up.railway.app")
#
# The file to modify is: app/src/main/java/com/vcam/utils/ApiClient.kt
# Look for the getServerUrl() method and update the default URL.
# ═══════════════════════════════════════════════════════════════════════════
